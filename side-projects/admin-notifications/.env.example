# Copy to admin-notifications/.env and fill with your Firebase Web app API key.
# Optional: because vite.config.ts uses envDir="..", you can also place these in the repo root .env.

# Required (public web config; keep API key in secret manager):
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=makerpars-oaslananka-mobil.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=makerpars-oaslananka-mobil
VITE_FIREBASE_APP_ID=1:462747480927:web:a00cb1781635ffed11bcea

# Optional but recommended (public web config):
VITE_FIREBASE_MESSAGING_SENDER_ID=462747480927
VITE_FIREBASE_STORAGE_BUCKET=makerpars-oaslananka-mobil.firebasestorage.app
VITE_FIREBASE_FUNCTIONS_REGION=europe-west1
# Optional override if you want to route calls through your own domain/reverse proxy
VITE_FUNCTIONS_BASE_URL=https://europe-west1-makerpars-oaslananka-mobil.cloudfunctions.net
# Optional UI hint only (authorization is decided by backend adminAccessCheck):
VITE_ADMIN_ALLOWED_EMAILS=admin1@example.com,admin2@example.com
# Optional reCAPTCHA v3 site key for high-impact admin actions:
VITE_GOOGLE_RECAPTCHA_SITE_KEY=
# Optional: Firebase App Check site key (required if Auth App Check enforcement is ON)
# You can set this to the same reCAPTCHA v3 key if it is configured in Firebase App Check for this web app.
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# Legacy fallback supported for apiKey only (repo root env compatibility):
# FIREBASE_WEB_API_KEY=your-firebase-web-api-key
