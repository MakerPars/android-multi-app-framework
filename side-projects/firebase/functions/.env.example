# Generated from Doppler before deploy:
#   npm run sync-env:doppler

# Required for ad performance weekly report
ADMOB_CLIENT_ID=
ADMOB_CLIENT_SECRET=
ADMOB_REFRESH_TOKEN=

# Either "pub-xxxxxxxxxxxxxxxx" or "accounts/pub-xxxxxxxxxxxxxxxx"
ADMOB_PUBLISHER_ID=

# Optional thresholds (defaults in code are used if omitted)
# AD_HEALTH_MIN_REQUESTS=500
# AD_HEALTH_FILL_RATE_THRESHOLD=55
# AD_HEALTH_SHOW_RATE_THRESHOLD=20

# Optional admin fallback allowlist (comma/space/semicolon separated emails)
# ADMIN_ALLOWED_EMAILS=makerpars@gmail.com,oaslananka@gmail.com

# Optional reCAPTCHA verification secret (used by recaptchaVerify endpoint)
# GOOGLE_RECAPTCHA_SECRET_KEY=
